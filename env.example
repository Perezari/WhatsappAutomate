# =============================================================
# Pulse · WhatsApp Backend — Configuration
# Copy this file to .env and adjust as needed (all values optional).
# =============================================================

# HTTP server
PORT=3001
HOST=127.0.0.1

# CORS — comma-separated origins, or "*" to allow any. Default: *.
# When the dashboard is opened from file://, Origin is "null", which
# CORS treats as opaque. Keep the default unless you front this with a proxy.
CORS_ORIGIN=*

# Storage
DB_PATH=./data/pulse.db
UPLOADS_DIR=./uploads

# Background tasks
# How often (seconds) to check for due scheduled & recurring messages.
SCHEDULE_TICK_INTERVAL=15
# Pause between sends inside a batch tick (ms) — anti-ban throttle.
SEND_THROTTLE_MS=1500
# Maximum messages dispatched per tick.
SEND_BATCH_LIMIT=10

# Puppeteer / Chromium
# If whatsapp-web.js can't find Chromium on your system, point it at one:
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
